{
  "name": "crsr",
  "version": "1.0.2",
  "description": "Terminal wrapper shell for Cursor Agent",
  "type": "module",
  "main": "dist/crsr.cjs",
  "scripts": {
    "dev": "tsx src/main.tsx",
    "prepare:version": "node ./scripts/sync-version.mjs",
    "prebuild": "npm run prepare:version",
    "build": "tsc -p tsconfig.json",
    "prebundle": "npm run prepare:version",
    "bundle": "esbuild src/main.tsx --bundle --platform=node --format=cjs --external:blessed --outfile=dist/crsr.cjs",
    "release": "npm run bundle && node ./scripts/install-local-wrapper.mjs",
    "prepackage:linux": "npm run prepare:version",
    "package:linux": "npm run bundle && mkdir -p release && pkg package.json --targets node18-linux-x64 --output release/crsr-linux-x64 --public-packages '*'",
    "start": "node dist/crsr.cjs",
    "test": "node --import tsx --test test/**/*.test.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "cursor",
    "agent",
    "shell",
    "tui",
    "crsr"
  ],
  "author": "",
  "license": "MIT",
  "bin": {
    "crsr": "./dist/crsr.cjs"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.5.0",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "pkg": {
    "assets": [
      "node_modules/blessed/usr/**/*",
      "node_modules/blessed/vendor/**/*"
    ]
  }
}
